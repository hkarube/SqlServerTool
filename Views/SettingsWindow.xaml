<Window x:Class="SqlServerTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="300" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- サーバー名 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="サーバー名"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                   Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,5"/>

        <!-- データベース名 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="データベース名"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                   Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,5"/>

        <!-- ユーザーID -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="ユーザーID"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                   Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,5"/>

        <!-- パスワード -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="パスワード"
                   VerticalAlignment="Center" Margin="0,5"/>
        <PasswordBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                     x:Name="PasswordBox"
                     PasswordChanged="PasswordBox_PasswordChanged"
                     Margin="0,5"/>

        <!-- 作業用フォルダ -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="作業用フォルダ"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="4" Grid.Column="1"
                   Text="{Binding WorkFolder, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,5,4,5"/>
        <Button    Grid.Row="4" Grid.Column="2" Content="参照..."
                   Command="{Binding BrowseWorkFolderCommand}"
                   Width="60" Margin="0,5"/>

        <!-- ボタン -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="登録"     Command="{Binding SaveCommand}"   Width="80" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Command="{Binding CancelCommand}" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
