<Window x:Class="SqlServerTool.Views.ExportDefinitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="テーブル定義書出力" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="12">

        <!-- ボタン行（下部） -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="全選択"   Command="{Binding SelectAllCommand}"   Width="70" Margin="0,0,6,0"/>
            <Button Content="全解除"   Command="{Binding DeselectAllCommand}" Width="70" Margin="0,0,16,0"/>
            <Button Content="開始"     Command="{Binding StartCommand}"       Width="70" Margin="0,0,6,0"/>
            <Button Content="閉じる"   Click="CloseButton_Click"              Width="70"/>
        </StackPanel>

        <!-- ステータス -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   Foreground="DarkBlue"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"/>

        <!-- メインコンテンツ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 出力設定 -->
            <GroupBox Grid.Row="0" Header="出力設定" Margin="0,0,0,8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="出力先"
                               VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox   Grid.Row="0" Grid.Column="1"
                               Text="{Binding OutputFilePath, UpdateSourceTrigger=PropertyChanged}"
                               VerticalAlignment="Center" Margin="4,4,4,4"/>
                    <Button    Grid.Row="0" Grid.Column="2" Content="参照..."
                               Command="{Binding BrowseFileCommand}" Width="60"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                              Content="すでに同じファイルが存在する場合は上書きする"
                              IsChecked="{Binding OverwriteExisting}" Margin="0,4"/>
                </Grid>
            </GroupBox>

            <!-- 出力オプション -->
            <GroupBox Grid.Row="1" Header="出力オプション" Margin="0,0,0,8" Padding="8">
                <WrapPanel>
                    <CheckBox Content="論理名列を含める"
                              IsChecked="{Binding IncludeLogicalName}" Margin="0,2,16,2"/>
                    <CheckBox Content="ヘッダーに色をつける"
                              IsChecked="{Binding ColorHeaders}" Margin="0,2,16,2"/>
                </WrapPanel>
            </GroupBox>

            <!-- テーブル一覧 -->
            <GroupBox Grid.Row="2" Header="テーブル" Padding="4">
                <ListBox ItemsSource="{Binding Tables}" SelectionMode="Multiple">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
