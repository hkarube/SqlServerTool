<Window x:Class="SqlServerTool.Views.SqlHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL 実行履歴" Height="520" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F8FF"
                  SelectionMode="Single"
                  MouseDoubleClick="HistoryGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="実行日時"
                    Binding="{Binding ExecutedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm:ss}'}"
                    Width="148"/>
                <DataGridTextColumn Header="操作"
                    Binding="{Binding OperationType}"
                    Width="100"/>
                <DataGridTextColumn Header="オブジェクト"
                    Binding="{Binding ObjectName}"
                    Width="150"/>
                <DataGridTextColumn Header="SQL プレビュー"
                    Binding="{Binding SqlPreview}"
                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Button Content="履歴をクリア" Width="110" HorizontalAlignment="Left"
                    Click="ClearButton_Click" Foreground="DarkRed"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="再適用 (ダブルクリック)" Width="160" Margin="0,0,8,0"
                        Click="ReapplyButton_Click" Foreground="DarkGreen"/>
                <Button Content="閉じる" Width="80"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
