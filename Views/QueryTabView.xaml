<UserControl x:Class="SqlServerTool.Views.QueryTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             AllowDrop="True">
    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ExecuteSqlCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"  MinWidth="120"/>
        </Grid.ColumnDefinitions>

        <!-- ─── 左ペイン: SQL エディタ + 結果 ─── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ツールバー + AvalonEdit -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,2">
                    <Button Content="▶ 実行 (F5)"
                            Command="{Binding ExecuteSqlCommand}"
                            Width="90" Height="26" Margin="0,0,8,0"/>
                    <Button Content="ヘッダ付コピー"
                            Command="{Binding CopyWithHeaderCommand}"
                            Width="100" Height="26" Margin="0,0,8,0"/>
                    <Button Content="保存"
                            Command="{Binding SaveSqlCommand}"
                            Width="60" Height="26"/>
                </StackPanel>
                <avalonEdit:TextEditor
                    Grid.Row="1"
                    x:Name="SqlEditor"
                    SyntaxHighlighting="TSQL"
                    FontFamily="Consolas" FontSize="13"
                    ShowLineNumbers="True"
                    AllowDrop="True"
                    Margin="4,0,4,0">
                    <avalonEdit:TextEditor.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="切り取り(_T)"   Command="ApplicationCommands.Cut"/>
                            <MenuItem Header="コピー(_C)"     Command="ApplicationCommands.Copy"/>
                            <MenuItem Header="貼り付け(_V)"   Command="ApplicationCommands.Paste"/>
                            <Separator/>
                            <MenuItem Header="全選択(_A)"     Command="ApplicationCommands.SelectAll"/>
                            <Separator/>
                            <MenuItem Header="元に戻す(_Z)"   Command="ApplicationCommands.Undo"/>
                            <MenuItem Header="やり直し(_Y)"   Command="ApplicationCommands.Redo"/>
                        </ContextMenu>
                    </avalonEdit:TextEditor.ContextMenu>
                </avalonEdit:TextEditor>
            </Grid>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                          Background="#DDDDDD"/>

            <!-- 結果グリッド -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding ResultTable}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F8FF"
                      Margin="4"/>

            <!-- ステータスバー -->
            <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="#CCCCCC"
                    BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="DarkBlue"
                           Margin="8,3" FontSize="12"/>
            </Border>
        </Grid>

        <!-- 垂直スプリッター -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#CCCCCC"/>

        <!-- ─── 右ペイン: オブジェクトツリー ─── -->
        <TreeView Grid.Column="2"
                  x:Name="ObjectTree"
                  ItemsSource="{Binding TreeNodes}"
                  Margin="0,4,4,4">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" Padding="2,1"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>
