<Window x:Class="SqlServerTool.Views.SqlPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="SQL プレビュー" Height="460" Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="InfoLabel" FontWeight="Bold" FontSize="13"/>
            <TextBlock Text="※ 実行前に内容を確認してください。実行は元に戻せません。"
                       Foreground="DarkRed" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <avalonEdit:TextEditor Grid.Row="1"
            x:Name="SqlEditor"
            SyntaxHighlighting="TSQL"
            FontFamily="Consolas" FontSize="13"
            ShowLineNumbers="True"
            IsReadOnly="True"
            Margin="0,0,0,8"/>

        <Grid Grid.Row="2">
            <Button Content="クリップボードにコピー" Width="140" HorizontalAlignment="Left"
                    Click="CopyButton_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ExecuteButton" Content="OK（保存実行）" Width="130" Margin="0,0,8,0"
                        Click="ExecuteButton_Click" Foreground="DarkGreen" FontWeight="Bold"/>
                <Button x:Name="CancelButton" Content="キャンセル（戻る）" Width="130"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
