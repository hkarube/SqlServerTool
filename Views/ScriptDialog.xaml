<Window x:Class="SqlServerTool.Views.ScriptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:SqlServerTool.Helpers"
        Title="スクリプト出力" Height="560" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <h:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Window.Resources>
    <DockPanel Margin="12">

        <!-- ボタン行（下部） -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="全選択"   Command="{Binding SelectAllCommand}"   Width="70" Margin="0,0,6,0"/>
            <Button Content="全解除"   Command="{Binding DeselectAllCommand}" Width="70" Margin="0,0,16,0"/>
            <Button Content="開始"     Command="{Binding StartCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                    Width="70" Margin="0,0,6,0"/>
            <Button Content="キャンセル" Click="CancelButton_Click" Width="80"/>
        </StackPanel>

        <!-- ステータス（下部） -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   Foreground="DarkBlue"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"/>

        <!-- メインコンテンツ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 出力設定 -->
            <GroupBox Grid.Row="0" Header="出力設定" Margin="0,0,0,8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="出力先"
                               VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox   Grid.Row="0" Grid.Column="1"
                               Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                               VerticalAlignment="Center" Margin="4,4,4,4"/>
                    <Button    Grid.Row="0" Grid.Column="2" Content="参照..."
                               Command="{Binding BrowseFolderCommand}" Width="60"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                              Content="すでに同じファイルが存在する場合は上書きする"
                              IsChecked="{Binding OverwriteExisting}" Margin="0,4"/>
                </Grid>
            </GroupBox>

            <!-- オプション -->
            <GroupBox Grid.Row="1" Header="出力オプション" Margin="0,0,0,8" Padding="8">
                <WrapPanel>
                    <CheckBox Content="DROP 文を出力する"                IsChecked="{Binding IncludeDrop}"        Margin="0,2,16,2"/>
                    <CheckBox Content="INSERT 文を出力する（データ）"     IsChecked="{Binding IncludeData}"        Margin="0,2,16,2"/>
                    <CheckBox Content="ファイルグループを出力する"         IsChecked="{Binding IncludeFilegroup}"   Margin="0,2,16,2"/>
                    <CheckBox Content="ビュー出力時に項目名を含める"       IsChecked="{Binding IncludeViewColumns}" Margin="0,2,16,2"/>
                </WrapPanel>
            </GroupBox>

            <!-- テーブル / ビュー / SP / ファンクション 選択 -->
            <TabControl Grid.Row="2">
                <TabItem Header="テーブル">
                    <ListBox ItemsSource="{Binding Tables}"
                             SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="ビュー">
                    <ListBox ItemsSource="{Binding Views}"
                             SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="ストアドプロシージャ">
                    <ListBox ItemsSource="{Binding StoredProcs}"
                             SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="ファンクション">
                    <ListBox ItemsSource="{Binding Functions}"
                             SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
            </TabControl>

        </Grid>
    </DockPanel>
</Window>
