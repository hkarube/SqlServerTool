<Window x:Class="SqlServerTool.Views.EditRowDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:SqlServerTool.Helpers"
        Title="行の編集" Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <h:InvertBoolConverter x:Key="InvertBool"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding TableName, StringFormat='テーブル：{0}'}"
                   FontWeight="Bold" Margin="0,0,0,8"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <!-- 列名・論理名・型 -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ColumnName}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LogicalName}"
                                           Foreground="DarkBlue" FontSize="10"
                                           Visibility="{Binding HasLogicalName,
                                               Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding DataType}"
                                           Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="PK" Foreground="DarkBlue"
                                           FontSize="10" FontWeight="Bold"
                                           Visibility="{Binding IsPrimaryKey,
                                           Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="IDENTITY" Foreground="Gray"
                                           FontSize="10" FontStyle="Italic"
                                           Visibility="{Binding IsIdentity,
                                           Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- IDENTITY列は自動採番表示 -->
                            <TextBlock Grid.Column="1" Grid.ColumnSpan="2"
                                       Text="（自動採番 - 入力不要）"
                                       Foreground="Gray" FontStyle="Italic"
                                       VerticalAlignment="Center" Margin="4,0"
                                       Visibility="{Binding IsIdentity,
                                           Converter={StaticResource BoolToVisibility}}"/>

                            <!-- 通常列の値入力 -->
                            <TextBox Grid.Column="1"
                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsNull, Converter={StaticResource InvertBool}}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="28" MaxHeight="80"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="4,0"
                                     Visibility="{Binding IsNotIdentity, Converter={StaticResource BoolToVisibility}}"/>

                            <!-- NULLチェック（IDENTITY以外） -->
                            <CheckBox Grid.Column="2"
                                      Content="NULL"
                                      IsChecked="{Binding IsNull}"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding IsNotIdentity, Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Button Content="新規追加" Width="90" HorizontalAlignment="Left"
                    Click="NewRowButton_Click" Foreground="DarkGreen"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Margin="0,0,8,0"
                        Command="{Binding ConfirmCommand}"
                        Click="OkButton_Click"/>
                <Button Content="キャンセル" Width="80"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>