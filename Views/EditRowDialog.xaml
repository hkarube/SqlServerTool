<Window x:Class="SqlServerTool.Views.EditRowDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:SqlServerTool.Helpers"
        Title="行の編集" Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <h:InvertBoolConverter x:Key="InvertBool"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding TableName, StringFormat='テーブル：{0}'}"
                   FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- フィールドレイアウトはコードビハインドで動的生成。
             MAX 型フィールドがある場合は * 行として拡張される。 -->
        <Grid Grid.Row="1" x:Name="FieldsGrid"/>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Button Content="新規追加" Width="90" HorizontalAlignment="Left"
                    Click="NewRowButton_Click" Foreground="DarkGreen"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Margin="0,0,8,0"
                        Command="{Binding ConfirmCommand}"
                        Click="OkButton_Click"/>
                <Button Content="キャンセル" Width="80"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>