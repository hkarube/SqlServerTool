<Window x:Class="SqlServerTool.Views.BulkCopyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="バルクコピー（CSV）" Height="560" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <TabControl Margin="8">

        <!-- ═══════════════════════════════════════ エクスポートタブ ═══ -->
        <TabItem Header="エクスポート（テーブル → CSV）">
            <DockPanel Margin="8">

                <!-- ボタン行 -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="全選択"   Command="{Binding ExportSelectAllCommand}"   Width="70" Margin="0,0,6,0"/>
                    <Button Content="全解除"   Command="{Binding ExportDeselectAllCommand}" Width="70" Margin="0,0,16,0"/>
                    <Button Content="開始"     Command="{Binding StartExportCommand}"       Width="70"/>
                </StackPanel>

                <!-- ステータス -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding ExportStatus}"
                           Foreground="DarkBlue" TextWrapping="Wrap" Margin="0,6,0,0"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 出力設定 -->
                    <GroupBox Grid.Row="0" Header="出力設定" Margin="0,0,0,8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="出力先"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="0" Grid.Column="1"
                                       Text="{Binding ExportFolder, UpdateSourceTrigger=PropertyChanged}"
                                       VerticalAlignment="Center" Margin="4,4,4,4"/>
                            <Button    Grid.Row="0" Grid.Column="2" Content="参照..."
                                       Command="{Binding BrowseExportFolderCommand}" Width="60"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ファイル名"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                       Text="テーブル名.csv（テーブルごとに自動生成）"
                                       Foreground="Gray" VerticalAlignment="Center" Margin="4,4"/>
                        </Grid>
                    </GroupBox>

                    <!-- オプション -->
                    <GroupBox Grid.Row="1" Header="出力オプション" Margin="0,0,0,8" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="文字コード" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox  Grid.Column="1" ItemsSource="{Binding EncodingOptions}"
                                       SelectedItem="{Binding ExportEncoding}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="区切り文字" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox  Grid.Column="3" ItemsSource="{Binding DelimiterOptions}"
                                       SelectedItem="{Binding ExportDelimiter}" Margin="0,0,12,0"/>
                            <CheckBox  Grid.Column="4" Content="ヘッダー行を含める"
                                       IsChecked="{Binding ExportHeader}" VerticalAlignment="Center"/>
                        </Grid>
                    </GroupBox>

                    <!-- テーブル一覧 -->
                    <GroupBox Grid.Row="2" Header="テーブル" Padding="4">
                        <ListBox ItemsSource="{Binding ExportTables}" SelectionMode="Multiple">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>
            </DockPanel>
        </TabItem>

        <!-- ═══════════════════════════════════════ インポートタブ ═══ -->
        <TabItem Header="インポート（CSV → テーブル）">
            <DockPanel Margin="8">

                <!-- ボタン行 -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="開始" Command="{Binding StartImportCommand}" Width="70"/>
                </StackPanel>

                <!-- ステータス -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding ImportStatus}"
                           Foreground="DarkBlue" TextWrapping="Wrap" Margin="0,6,0,0"/>

                <GroupBox Header="インポート設定" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- CSVファイル -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CSVファイル"
                                   VerticalAlignment="Center" Margin="0,6"/>
                        <TextBox   Grid.Row="0" Grid.Column="1"
                                   Text="{Binding ImportFilePath, UpdateSourceTrigger=PropertyChanged}"
                                   VerticalAlignment="Center" Margin="4,6,4,6"/>
                        <Button    Grid.Row="0" Grid.Column="2" Content="参照..."
                                   Command="{Binding BrowseImportFileCommand}" Width="60"/>

                        <!-- インポート先テーブル -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="インポート先"
                                   VerticalAlignment="Center" Margin="0,6"/>
                        <ComboBox  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   ItemsSource="{Binding AllTableNames}"
                                   SelectedItem="{Binding ImportTargetTable}"
                                   IsEditable="False" Margin="4,6,0,6"/>

                        <!-- オプション行1 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="文字コード"
                                   VerticalAlignment="Center" Margin="0,6"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Margin="4,6">
                            <ComboBox ItemsSource="{Binding EncodingOptions}"
                                      SelectedItem="{Binding ImportEncoding}" Width="110" Margin="0,0,16,0"/>
                            <TextBlock Text="区切り文字" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding DelimiterOptions}"
                                      SelectedItem="{Binding ImportDelimiter}" Width="120"/>
                        </StackPanel>

                        <!-- オプション行2 -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Margin="0,8">
                            <CheckBox Content="先頭行はヘッダー行として扱う"
                                      IsChecked="{Binding ImportHeader}" Margin="0,0,24,0"/>
                            <CheckBox Content="既存データを削除してからインポート"
                                      IsChecked="{Binding TruncateFirst}" Foreground="DarkRed"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </DockPanel>
        </TabItem>

    </TabControl>
</Window>
